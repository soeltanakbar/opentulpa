# OpenLIT server settings (plugin-local env for docker compose)
OPENLIT_AUTH_DISABLED=true
OPENLIT_SMTP_ENABLED=false

# ClickHouse backing store for OpenLIT
OPENLIT_CLICKHOUSE_HOST=clickhouse
OPENLIT_CLICKHOUSE_PORT=8123
OPENLIT_CLICKHOUSE_USER=default
OPENLIT_CLICKHOUSE_PASSWORD=
OPENLIT_CLICKHOUSE_DB=default
OPENLIT_CLICKHOUSE_SSL=false
OPENLIT_INITDB_CLICKHOUSE_URL=clickhouse://default:@clickhouse:8123/default

